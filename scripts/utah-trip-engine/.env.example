# Database
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:54350/utah_engine

# LLM (Anthropic Claude Haiku 4.5 by default)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Pilot anchor — Moab city
MOAB_LAT=38.5733
MOAB_LNG=-109.5498
RADIUS_MI=50

# Cost cap (USD). Pipeline halts if running spend would exceed this.
BUDGET_CAP=10.0

# Optional: Reddit JSON API needs a User-Agent
REDDIT_USER_AGENT=roamswild-utah-pilot/0.1 (contact: hello@roamswild.app)
