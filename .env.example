# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Google Maps - Get from https://console.cloud.google.com/
# Restrict this key to your domains in the Google Cloud Console
VITE_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# Supabase - Get from your Supabase project settings
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"

# Flickr API - Get from https://www.flickr.com/services/api/
VITE_FLICKR_API_KEY="your-flickr-api-key"

# Recreation.gov API - Get from https://ridb.recreation.gov/
VITE_RIDB_API_KEY="your-ridb-api-key"

# Tomorrow.io Weather API - Get from https://www.tomorrow.io/
VITE_TOMORROW_IO_API_KEY="your-tomorrow-io-api-key"
